#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Default model
MODEL="${WHISPERX_MODEL:-large-v3}"

show_help() {
    echo "Usage: $(basename "$0") /path/to/audio [options]"
    echo ""
    echo "Transcribe audio/video files using local MLX-Whisper."
    echo ""
    echo "Options:"
    echo "  --model MODEL      Whisper model (tiny, base, small, medium, large-v3)"
    echo "                     Default: large-v3 (or WHISPERX_MODEL env var)"
    echo "  --speakers NAMES   Comma-separated speaker names (e.g., \"Alice,Bob\")"
    echo "  --help             Show this help message"
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") meeting.m4a"
    echo "  $(basename "$0") video.mp4 --model small"
    echo "  $(basename "$0") call.wav --speakers \"John,Jane\""
}

if [ "$#" -lt 1 ]; then
    show_help
    exit 2
fi

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    show_help
    exit 0
fi

INPUT="$1"
shift || true

# Parse arguments
SPEAKERS=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --speakers)
            SPEAKERS="$2"
            shift 2
            ;;
        --model)
            MODEL="$2"
            shift 2
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            show_help
            exit 1
            ;;
    esac
done

# Validate input file
if [ ! -f "$INPUT" ]; then
    echo "❌ File not found: $INPUT" >&2
    exit 1
fi

# Get base name for output files
INPUT_DIR="$(dirname "$INPUT")"
INPUT_BASE="$(basename "$INPUT" | sed 's/\.[^.]*$//')"
OUTPUT_DIR="${INPUT_DIR}"

# Video formats need audio extraction
VIDEO_REGEX='\.(mp4|mkv|mov|avi|webm|m4v|wmv|flv)$'
AUDIO_REGEX='\.(m4a|mp3|wav|flac|ogg|aac|wma|opus)$'

if [[ "$INPUT" =~ $VIDEO_REGEX ]]; then
    echo "📹 Extracting audio from video..."
    AUDIO="$(mktemp -t whisperx_audio.XXXXXX).wav"
    trap 'rm -f "$AUDIO"' EXIT
    ffmpeg -i "$INPUT" -vn -acodec pcm_s16le -ar 16000 -ac 1 "$AUDIO" -y -loglevel error
    echo "✅ Audio extracted"
elif [[ "$INPUT" =~ $AUDIO_REGEX ]]; then
    AUDIO="$INPUT"
else
    echo "⚠️  Unrecognized format, attempting to process anyway..."
    AUDIO="$INPUT"
fi

# Export variables for Python script
export AUDIO
export OUTPUT_DIR
export INPUT_BASE
export MODEL

echo "🎙️  Starting transcription with local MLX-Whisper..."
echo "    Model: $MODEL"

# Transcribe using local MLX-Whisper
python3 << 'PYTHON_SCRIPT'
import os
import sys

audio_file = os.environ['AUDIO']
output_dir = os.environ['OUTPUT_DIR']
input_base = os.environ['INPUT_BASE']
model_size = os.environ['MODEL']

# Add script directory to path for imports
script_dir = os.path.dirname(os.path.abspath(__file__)) if '__file__' in dir() else os.getcwd()
sys.path.insert(0, script_dir)

try:
    from whisperx_app.transcriber import Transcriber
    from whisperx_app.output_writer import write_all_formats
    from whisperx_app.diarization import diarize_transcript, is_ollama_available
except ImportError as e:
    print(f"❌ Could not import whisperx_app modules: {e}")
    print("   Make sure you're running from the whisperx directory.")
    sys.exit(1)

# Get file size for display
file_size_mb = os.path.getsize(audio_file) / (1024 * 1024)
print(f"📂 Processing {file_size_mb:.1f}MB audio file...")

# Transcribe
print("🔄 Transcribing (this may take a moment on first run to download the model)...")
transcriber = Transcriber(model_size=model_size)
transcript = transcriber.transcribe(audio_file)

# Speaker diarization with Ollama
if is_ollama_available():
    print("🤖 Identifying speakers with Ollama...")
    transcript = diarize_transcript(transcript)

# Write output files
from pathlib import Path
files = write_all_formats(transcript, Path(output_dir), input_base)
print(f"✅ Transcription saved to {output_dir}")
PYTHON_SCRIPT

echo "✅ Transcription complete"

# Find the output JSON file
JSON_FILE="${OUTPUT_DIR}/${INPUT_BASE}.json"

# Apply manual speaker names if provided
if [ -f "$JSON_FILE" ] && [ -n "$SPEAKERS" ]; then
    echo "📝 Applying speaker names: $SPEAKERS"
    IFS=',' read -ra SPEAKER_ARRAY <<< "$SPEAKERS"
    SPEAKER_MAP="{\"SPEAKER_00\": \"${SPEAKER_ARRAY[0]:-Speaker 1}\", \"SPEAKER_01\": \"${SPEAKER_ARRAY[1]:-Speaker 2}\"}"
    
    python3 -c "
import json

speaker_map = json.loads('$SPEAKER_MAP')
json_file = '$JSON_FILE'
base = json_file.rsplit('.', 1)[0]

with open(json_file) as f:
    data = json.load(f)
for seg in data.get('segments', []):
    old_speaker = seg.get('speaker', '')
    if old_speaker in speaker_map:
        seg['speaker'] = speaker_map[old_speaker]
with open(json_file, 'w') as f:
    json.dump(data, f, indent=2)

for ext in ['.txt', '.srt', '.vtt']:
    try:
        with open(base + ext) as f:
            content = f.read()
        for old, new in speaker_map.items():
            content = content.replace(f'[{old}]', f'[{new}]')
            content = content.replace(old, new)
        with open(base + ext, 'w') as f:
            f.write(content)
    except: pass
print('✅ Speaker names applied')
"
fi

echo "📁 Output files in: $OUTPUT_DIR"
